# =============================================================================
# basekit environment variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this file (.env.example) IS committed.
# See .claude/setup.md for step-by-step instructions on obtaining each value.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — https://supabase.com → Project → Settings → API
# -----------------------------------------------------------------------------

# Project URL (looks like https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon / public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — BYPASSES RLS. Server-side only. Never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here


# -----------------------------------------------------------------------------
# Stripe — https://dashboard.stripe.com → Developers → API keys
# -----------------------------------------------------------------------------

# Secret key (sk_test_... for dev, sk_live_... for prod). Server-only.
STRIPE_SECRET_KEY=sk_test_your_key_here

# Publishable key (pk_test_... for dev). Safe to expose.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Webhook signing secret (whsec_...).
# Local dev: get from `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# Prod: from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Stripe Price IDs (price_...). Create these products in Stripe first.
# See .claude/setup.md section 4b for prices ($29/mo Pro, $99/mo Enterprise, annual = 20% off).
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual_id
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly_id
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_enterprise_annual_id


# -----------------------------------------------------------------------------
# Resend — https://resend.com → API Keys
# -----------------------------------------------------------------------------

# Resend API key (re_...). Server-only.
RESEND_API_KEY=re_your_key_here

# From-address (must be a verified Resend domain, or use onboarding@resend.dev for sandbox)
FROM_EMAIL=hello@basekit.dev


# -----------------------------------------------------------------------------
# Upstash — https://upstash.com → Redis → your database
# -----------------------------------------------------------------------------

# Used for rate limiting via @upstash/ratelimit.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here


# -----------------------------------------------------------------------------
# Sentry — https://sentry.io → Project Settings
# -----------------------------------------------------------------------------

# DSN (public_key@host/project_id). Used for both client and server.
SENTRY_DSN=https://yourdsn@sentry.io/yourproject

# Auth token for source-map upload in CI (Project Settings → Auth Tokens).
# Local dev: can be left blank. CI must set this in repository secrets.
SENTRY_AUTH_TOKEN=


# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------

# The fully-qualified URL of the running app (used for OAuth callbacks, email links).
# Dev: http://localhost:3000
# Preview: the Vercel preview URL
# Prod: https://basekit.dev (or your domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
